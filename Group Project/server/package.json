{
  "name": "civiccase-server",
  "version": "1.0.0",
  "description": "Backend for CivicCase AI-Powered Local Issue Tracker",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "dev:auth": "nodemon src/microservices/authService.js",
    "dev:issue": "nodemon src/microservices/issueService.js",
    "dev:ai": "nodemon src/microservices/aiService.js",
    "dev:gateway": "nodemon src/index.js",
    "dev:all": "concurrently \"npm run dev:auth\" \"npm run dev:issue\" \"npm run dev:ai\" \"npm run dev:gateway\"",
    "start": "node src/index.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@apollo/server": "^4.11.3",
    "@langchain/core": "^1.1.40",
    "@langchain/google-genai": "^2.1.27",
    "@langchain/langgraph": "^1.2.8",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.15.1",
    "uuid": "^9.0.1",
    "validator": "^13.12.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.1.10"
  }
}
